<?xml version="1.0" encoding="UTF-8"?>

<configuration>

    <appender name="STDOUT"
              class="ch.qos.logback.core.ConsoleAppender">

        <encoder>

            <pattern>
                %d{yyMMdd}|%-20thread|%-5level|%logger{36}|%25M|%msg%n
            </pattern>

        </encoder>

    </appender>

    <root level="INFO">

        <appender-ref ref="STDOUT"/>

    </root>

    <logger name="com.cognizant.springlearn"
            level="DEBUG"/>

</configuration>