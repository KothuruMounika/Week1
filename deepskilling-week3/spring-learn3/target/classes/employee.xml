<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Department beans -->
    <bean id="department1" class="com.cognizant.springlearn3.model.Department">
        <property name="id" value="101"/>
        <property name="name" value="HR"/>
    </bean>

    <bean id="department2" class="com.cognizant.springlearn3.model.Department">
        <property name="id" value="102"/>
        <property name="name" value="IT"/>
    </bean>

    <!-- REQUIRED: departmentList -->
    <bean id="departmentList" class="java.util.ArrayList">
        <constructor-arg>
            <list>
                <ref bean="department1"/>
                <ref bean="department2"/>
            </list>
        </constructor-arg>
    </bean>

    <!-- Skill beans -->
    <bean id="skill1" class="com.cognizant.springlearn3.model.Skill">
        <property name="id" value="201"/>
        <property name="name" value="Java"/>
    </bean>

    <bean id="skill2" class="com.cognizant.springlearn3.model.Skill">
        <property name="id" value="202"/>
        <property name="name" value="Spring"/>
    </bean>

    <!-- Employee beans -->
    <bean id="employee1" class="com.cognizant.springlearn3.model.Employee">
        <property name="id" value="1"/>
        <property name="name" value="John"/>
        <property name="salary" value="50000"/>
        <property name="permanent" value="true"/>
        <property name="department" ref="department1"/>
        <property name="skillList">
            <list>
                <ref bean="skill1"/>
                <ref bean="skill2"/>
            </list>
        </property>
    </bean>

    <bean id="employee2" class="com.cognizant.springlearn3.model.Employee">
        <property name="id" value="2"/>
        <property name="name" value="Jane"/>
        <property name="salary" value="60000"/>
        <property name="permanent" value="false"/>
        <property name="department" ref="department2"/>
        <property name="skillList">
            <list>
                <ref bean="skill2"/>
            </list>
        </property>
    </bean>

    <!-- REQUIRED: employeeList (THIS FIXES YOUR ERROR) -->
    <bean id="employeeList" class="java.util.ArrayList">
        <constructor-arg>
            <list>
                <ref bean="employee1"/>
                <ref bean="employee2"/>
            </list>
        </constructor-arg>
    </bean>

</beans>